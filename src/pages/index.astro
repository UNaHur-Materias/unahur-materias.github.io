---
// src/pages/index.astro
import { getCollection } from 'astro:content';
import CardAsignacion from '../components/CardAsignacion.astro';
import HeaderUni from '../components/HeaderUni.astro';

const todasLasAsignaciones = await getCollection('asignaciones');
const asignacionesActivas = todasLasAsignaciones.filter(asig => asig.data.active === true);
---

<html lang="es">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>UNAHUR - Instituto de Tecnología e Ingeniería</title>
	<style>
		body { 
			font-family: system-ui, -apple-system, sans-serif; 
			background-color: #0b0f19; 
			color: #f1f5f9; 
			margin: 0; 
			padding: 2rem 1rem;
		}
		.container { 
			max-width: 1000px; 
			margin: 0 auto; 
		}
		h1 { 
			font-size: 2.25rem;
			font-weight: 800;
			color: #ffffff; 
			margin: 0 0 0.5rem 0; 
			letter-spacing: -0.025em;
		}
		h1 span { color: #009bc3; }
		.subtitle { 
			color: #94a3b8; 
			font-size: 1.05rem;
			margin: 0;
		}
		.grid { 
			display: grid; 
			grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); 
			gap: 2rem; 
		}
	</style>
</head>
<body>
	<div class="container">
		<!-- El Header recibe el bloque de títulos y los deja a la izquierda -->
		<HeaderUni>
			<h1>Asignaciones <span>Disponibles</span></h1>
			<p class="subtitle">Entorno de gestión de repositorios y entregas de código.</p>
		</HeaderUni>
		
		<main class="grid">
			{asignacionesActivas.length > 0 ? (
				asignacionesActivas.map(asig => (
					<CardAsignacion 
						title={asig.data.title} 
						description={asig.data.description || asig.data.descripcion} 
						slug={asig.slug} 
					/>
				))
			) : (
				<p style="grid-column: 1/-1; text-align: center; color: #64748b; background: #131926; padding: 3rem; border-radius: 12px; border: 1px dashed #1e293b;">
					No hay asignaciones activas en este momento.
				</p>
			)}
		</main>
	</div>
</body>
</html>