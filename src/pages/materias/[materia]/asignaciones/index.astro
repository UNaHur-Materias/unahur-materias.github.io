---
// src/pages/materias/[materia]/asignaciones/index.astro
import { getCollection } from "astro:content";
import HeaderUni from "@components/HeaderUni.astro";
import UserProfile from "@components/UserProfile.astro";
import Footer from "@components/Footer.astro";

export async function getStaticPaths() {
	const todoElContenido = await getCollection("materias");
	const carpetasUnicas = [...new Set(todoElContenido.map(item => item.slug.split("/")[0]))];
	return carpetasUnicas.map(materia => ({ params: { materia } }));
}

const { materia } = Astro.params;
const todoElContenido = await getCollection("materias");

const infoMateria = todoElContenido.find(item => item.slug.startsWith(materia + "/") && item.slug.split("/").length === 2);
const nombreMateria = infoMateria ? infoMateria.data.title : materia;

const asignacionesActivas = todoElContenido.filter((item) => {
	const partes = item.slug.split("/");
	return partes[0] === materia && partes[1] === "asignaciones" && (item.data as any).active !== false;
});

const formatearFecha = (fecha: any) => {
	if (!fecha) return null;
	return new Date(fecha).toLocaleDateString("es-AR", {
		day: "numeric",
		month: "short",
		year: "numeric",
		timeZone: "UTC",
	});
};
---
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Asignaciones - {nombreMateria}</title>
		<style>
			body { font-family: system-ui, sans-serif; background-color: #0b0f19; color: #f1f5f9; padding: 2rem 1rem; margin: 0; }
			.container { max-width: 850px; margin: 0 auto; }
			.nav-box { margin: 1rem 0 2rem 0; display: flex; justify-content: space-between; align-items: center; }
			.link-azul { color: #009bc3; text-decoration: none; font-weight: 600; font-size: 0.9rem; }
			.link-azul:hover { color: #70b043; }
			.btn-historial { background: rgba(255,255,255,0.05); padding: 0.5rem 1rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); color: #94a3b8; text-decoration: none; font-size: 0.85rem; font-weight: 600; }
			.btn-historial:hover { border-color: #ff9e1b; color: #fff; }
			h1 { font-size: 2rem; color: #ffffff; margin: 0; font-weight: 800; }
			.section-title { font-size: 1.25rem; color: #f39200; margin: 2rem 0 1rem 0; font-weight: 700; text-transform: uppercase; }
			.asig-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.25rem; }
			.asig-card { background: #111726; padding: 1.5rem; border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); color: #fff; text-decoration: none; display: flex; flex-direction: column; gap: 0.5rem; transition: all 0.2s; }
			.asig-card:hover { border-color: #70b043; transform: translateY(-2px); }
			.asig-title-row { display: flex; justify-content: space-between; align-items: center; font-weight: 700; }
			.asig-date { font-size: 0.75rem; color: #64748b; margin-top: auto; padding-top: 0.5rem; border-top: 1px solid rgba(255,255,255,0.02); }
		</style>
	</head>
	<body>
		<div class="container">
			<HeaderUni><h1>{nombreMateria}</h1></HeaderUni>
			<UserProfile />
			<div class="nav-box">
				<a href="/" class="link-azul">← Volver al inicio</a>
				<a href={`/materias/${materia}/historial`} class="btn-historial">Ver Historial de Entregas →</a>
			</div>
			<main>
				<h2 class="section-title">Asignaciones Activas</h2>
				<div class="asig-grid">
					{asignacionesActivas.map((item) => {
						const dataAsig = item.data as any;
						const fechaPub = formatearFecha(dataAsig.fechaPublicacion);
						const archivoSlug = item.slug.split("/").pop();
						return (
							<a href={`/materias/${materia}/asignaciones/${archivoSlug}`} class="asig-card">
								<div class="asig-title-row">
									<span>{dataAsig.title}</span>
									<span style="color: #70b043;">→</span>
								</div>
								{fechaPub && <span class="asig-date">Publicado: {fechaPub}</span>}
							</a>
						);
					})}
				</div>
			</main>
			<Footer />
		</div>
	</body>
</html>