// src/components/Footer.astro
---

<footer class="main-footer">
    <p>
        Desarrollado por docentes y estudiantes de la Universidad Nacional de
        Hurlingham
    </p>
    <div class="footer-links">
        <a
            href="mailto:mauricioenrique.pintos@estudiantes.unahur.edu.ar"
            class="footer-link"
        >
            <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path><polyline points="22,6 12,13 2,6"></polyline></svg
            >
            Contacto
        </a>
        <a
            href="https://github.com/mauriciopintos"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link"
        >
            <svg viewBox="0 0 24 24" fill="currentColor"
                ><path
                    d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                ></path></svg
            >
            GitHub
        </a>
    </div>
</footer>

<style>
    /* --- ESTILOS DEL FOOTER GLOBAL --- */
    .main-footer {
        margin-top: 5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 2rem;
        padding-bottom: 2rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .main-footer p {
        margin: 0;
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 500;
    }

    .footer-links {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
    }

    .footer-link {
        color: #94a3b8;
        text-decoration: none;
        font-size: 0.85rem;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: color 0.2s ease;
    }

    .footer-link:hover {
        color: #00a3e0; /* Celeste UNaHur */
    }

    .footer-link svg {
        width: 16px;
        height: 16px;
        opacity: 0.8;
    }
</style>
